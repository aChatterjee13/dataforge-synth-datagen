# =============================================================================
# DataForge Backend — Environment Configuration
# =============================================================================
# Copy this file:  cp .env.example .env
# Then fill in your values below.
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI API Configuration (optional)
# -----------------------------------------------------------------------------
# Required only for GPT-powered features: PDF generation, API test generation,
# DB test generation, LLM row augmentation.
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_API_ENDPOINT=https://api.openai.com/v1/chat/completions

# For GPT-4o Mini (recommended - faster and cheaper)
# Just set the API key above and select "gpt-4o-mini" in the UI

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# SQLite (default) — no external setup required
DATABASE_URL=sqlite:///./dataforge.db

# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/dataforge

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# CORS (comma-separated allowed origins)
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# Upload & Storage
# -----------------------------------------------------------------------------
# Maximum upload size in bytes (default: 100 MB)
MAX_UPLOAD_SIZE=104857600

UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
